{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "Paste",
  "version": "0.1.0",
  "identifier": "tech.paste.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Paste",
        "label": "main",
        "width": 2400,
        "height": 1400,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "fullscreen": true,
        "transparent": true,
        "skipTaskbar": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "wl-clipboard",
          "xdotool"
        ],
        "recommends": [
          "ydotool",
          "wtype"
        ],
        "section": "utils",
        "priority": "optional"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "category": "Utility",
    "shortDescription": "Clipboard manager with text expansion for Linux",
    "longDescription": "macOS Paste-quality clipboard management with integrated text expansion, built natively for Linux. Features a visual filmstrip history, pinboards, search, paste stack, and a full text expander with macros."
  }
}
